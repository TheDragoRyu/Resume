{
  "name": "portfolio-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "validate": "tsx scripts/validate-content.ts",
    "prebuild": "npm run validate",
    "build": "next build",
    "start": "npx serve out",
    "preview": "npx serve out --listen tcp://0.0.0.0:4000",
    "deploy:test": "fuser -k 4000/tcp 2>/dev/null; npm run build && npx serve out --listen tcp://0.0.0.0:4000",
    "sync:fetch": "tsx scripts/sync-github-projects.ts",
    "sync:generate": "tsx scripts/generate-project-content.ts",
    "sync-projects": "npm run sync:fetch && npm run sync:generate"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.0",
    "@react-three/fiber": "^9.5.0",
    "gray-matter": "^4.0.3",
    "next": "^15.1.0",
    "posthog-js": "^1.359.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.171.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
